{
  "name": "diffly",
  "private": true,
  "version": "0.1.6-rc.4",
  "description": "Desktop file and directory diff tool built with Svelte and Tauri.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:debug": "vite build --minify false --outDir dist-debug",
    "build:ensure": "node scripts/ensure-frontend-build.mjs",
    "build:ensure:debug": "node scripts/ensure-frontend-build.mjs --debug",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri": "npx tauri",
    "tauri:dev": "npx tauri dev --config src-tauri/tauri.build.conf.json -- --no-default-features --features window-state,debug-log",
    "tauri:build": "node scripts/run-tauri-debug-build.mjs",
    "tauri:build:full": "npm run build:ensure && npx tauri build --debug --no-bundle --config src-tauri/tauri.release.conf.json --features prerelease-updater",
    "tauri:build:release": "npm run build && npx tauri build --features prerelease-updater --no-bundle --config src-tauri/tauri.release.conf.json",
    "tauri:package": "npx tauri build --features prerelease-updater --bundles nsis --config src-tauri/tauri.release.conf.json",
    "tauri:package:all": "npx tauri build --features prerelease-updater --config src-tauri/tauri.release.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/prismjs": "^1.26.6",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
