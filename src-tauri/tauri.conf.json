{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Diffly",
  "version": "0.1.4-beta.1",
  "identifier": "com.diffly.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Diffly",
        "width": 1480,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 680,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "capabilities": [
        "debug-fast"
      ],
      "csp": "default-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline' http://localhost:1420; font-src 'self' data:; script-src 'self' http://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
